<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <!--
            Required for Payment Request API (Google Pay) inside ZeroSettleWebViewActivity's
            WebView. Without these, WebSettingsCompat.setPaymentRequestEnabled() can be
            flipped on but the WebView still cannot resolve Google Pay's payment handler
            and the in-page Stripe ExpressCheckoutElement renders no wallet row.
            Reference: https://developers.google.com/pay/api/android/guides/recipes/using-android-webview
        -->
        <intent>
            <action android:name="org.chromium.intent.action.PAY" />
        </intent>
        <intent>
            <action android:name="org.chromium.intent.action.IS_READY_TO_PAY" />
        </intent>
        <intent>
            <action android:name="org.chromium.intent.action.UPDATE_PAYMENT_DETAILS" />
        </intent>
    </queries>

    <application>
        <!--
            ZeroSettleWebViewActivity — hosts INLINE/SHEET dashboard
            presentation choices in an in-app WebView. Auto-registered so
            adopters of the headless :core module get WebView checkout
            without manifest edits. Uses a platform Material.Light theme
            (no AppCompat dep in :core). `configChanges` keeps the WebView
            alive across rotation mid-payment.
        -->
        <activity
            android:name=".checkout.ZeroSettleWebViewActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Material.Light.NoActionBar"
            android:configChanges="orientation|screenSize|keyboardHidden" />
    </application>
</manifest>
